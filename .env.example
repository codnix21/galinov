APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=ru
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

# Автопроверка документов / ЕГРН (true = тестовый режим, без случайных отказов)
DOCUMENT_VERIFICATION_DEMO=true

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Почта: еженедельные отчёты (app:send-weekly-report-email), тест: php artisan app:test-notifications
MAIL_MAILER=smtp
MAIL_HOST=mail.irk138.ru
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=agn@irk138.ru
MAIL_PASSWORD=
MAIL_SCHEME=
# false — только на локальной машине при ошибке SSL сертификата
MAIL_VERIFY_PEER=true
MAIL_FROM_ADDRESS="agn@irk138.ru"
MAIL_FROM_NAME="Агентство недвижимости"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# DaData (подсказки адресов)
DADATA_API_KEY=
DADATA_SECRET_KEY=

# Yandex Maps: геокодер и JavaScript API карты (можно один ключ)
YANDEX_GEOCODER_API_KEY=
YANDEX_MAPS_API_KEY=

# Telegram Bot — уведомления (создайте бота через @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=
# socks5://127.0.0.1:10808 или http://127.0.0.1:7890 — если Telegram API недоступен напрямую
TELEGRAM_PROXY=

# Pexels API — фото для сидера (бесплатно: https://www.pexels.com/api/)
PEXELS_API_KEY=

# Robokassa — идентификатор и пароли строго из кабинета (Мои магазины → Технические настройки)
# При ROBOKASSA_TEST=true используйте ТЕСТОВЫЕ пароль №1 и №2, не боевые
# Ошибка 26 = неверный идентификатор магазина (MerchantLogin)
ROBOKASSA_LOGIN=
ROBOKASSA_PASSWORD1=
ROBOKASSA_PASSWORD2=
ROBOKASSA_TEST=true
ROBOKASSA_HASH=md5
# PAYMENT_TEST_GATEWAY=true  # старый тестовый шлюз с фейковой картой

# APP_URL=https://agn.irk138.ru
