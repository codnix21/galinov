APP_NAME="Агентство недвижимости"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.example

APP_LOCALE=ru
APP_FALLBACK_LOCALE=ru
APP_FAKER_LOCALE=ru_RU

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=galinov
DB_USERNAME=galinov
DB_PASSWORD=change_me_strong_password
MYSQL_ROOT_PASSWORD=change_me_root_password

SESSION_DRIVER=database
SESSION_LIFETIME=120

QUEUE_CONNECTION=database
CACHE_STORE=database
FILESYSTEM_DISK=local

# Почта на хосте VPS (Postfix), не mail.irk138.ru снаружи — из контейнера идём на хост:
MAIL_MAILER=smtp
MAIL_HOST=host.docker.internal
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=agn@irk138.ru
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=agn@irk138.ru
MAIL_FROM_NAME="${APP_NAME}"
MAIL_VERIFY_PEER=false

DADATA_API_KEY=
DADATA_SECRET_KEY=
YANDEX_GEOCODER_API_KEY=
YANDEX_MAPS_API_KEY=

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=
# На сервере оставьте пустым (прокси только для разработки с ПК)
TELEGRAM_PROXY=
